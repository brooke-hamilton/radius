# Container registry and tag for the Radius control-plane images.
REGISTRY=ghcr.io/radius-project
TAG=latest

# Deployment Engine image (separate repo/tag from the Go components).
DE_IMAGE=ghcr.io/radius-project/deployment-engine:latest

# k3s image used to provide the in-Compose Kubernetes API.
K3S_VERSION=v1.33.4-k3s1

# kubectl image used by the Kubernetes bootstrap job.
KUBECTL_VERSION=1.33.4

# PostgreSQL superuser password (used by the bootstrap job and the components).
POSTGRES_PASSWORD=radius_pass
