{
  "name": "Radius - Contributor",
  // For details see https://github.com/radius-project/radius/tree/main/docs/contributing/contributing-code/contributing-code-prerequisites
  // IMPORTANT: Keep this file in sync with .github/workflows/copilot-setup-steps.yml,
  // which provisions the same environment for the GitHub Copilot coding agent.
  // A change to languages, tools, or versions here should be mirrored there.
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-24.04",
  "features": {
    //Git and GitHub Setup
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {},
    //Programming languages
    "ghcr.io/devcontainers/features/go:1": {},
    "ghcr.io/guiyomh/features/gotestsum:0.1.1": {},
    // Keep this version aligned with .node-version (the source of truth used by
    // CI and copilot-setup-steps.yml).
    "ghcr.io/devcontainers/features/node:2": {
      "version": "24"
    },
    // Keep this version aligned with .python-version (the source of truth used
    // by CI and copilot-setup-steps.yml).
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.14"
    },
    //Container and K8s
    "ghcr.io/devcontainers/features/kubectl-helm-minikube:1": {
      "minikube": "none",
      "helm": "3.19.4"
    },
    "ghcr.io/devcontainers/features/docker-in-docker:3.0.1": {
      "version": "latest",
      "moby": true
    },
    //Tools
    "ghcr.io/eitsupi/devcontainer-features/jq-likes:2": {},
    "ghcr.io/mpriscella/features/kind:1": {},
    "ghcr.io/rio/features/k3d:1": {},
    "ghcr.io/dhoeric/features/stern:1": {},
    //Dapr
    "ghcr.io/dapr/cli/dapr-cli:0": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "redhat.vscode-yaml",
        "golang.go",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-azuretools.vscode-bicep",
        "ms-kubernetes-tools.vscode-kubernetes-tools",
        "ms-vscode.makefile-tools",
        "timonwong.shellcheck",
        "typespec.typespec-vscode"
      ]
    }
  },
  "postCreateCommand": ".devcontainer/post-create.sh",
  "hostRequirements": {
    "memory": "8gb"
  }
}
